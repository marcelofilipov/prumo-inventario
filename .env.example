# Configuração do Firebase para apps/web
# Copie para .env.local (nunca commitar o .env.local real)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Slug da Loja piloto (usado como lojaId no Firestore)
VITE_LOJA_ID=joao-ramalho-107

# Opcional: aponta o app para os emuladores locais (Auth/Firestore) para testar
# localmente. Deixe vazio/false para usar o Firebase real.
VITE_USE_EMULATORS=false
