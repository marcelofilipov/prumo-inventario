rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Autorização por DOCUMENTO (sem custom claims / sem Cloud Functions):
    // o papel vem de lojas/{lojaId}/membros/{uid}. Membro com disabled==true
    // perde o acesso. Escolha compatível com o plano Spark/free.
    function meuMembro(lojaId) {
      return get(/databases/$(database)/documents/lojas/$(lojaId)/membros/$(request.auth.uid)).data;
    }

    function ehMembroAtivo(lojaId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/lojas/$(lojaId)/membros/$(request.auth.uid))
        // .get() com default tolera docs legados sem o campo `disabled`.
        && meuMembro(lojaId).get('disabled', false) != true;
    }

    function papel(lojaId) {
      return ehMembroAtivo(lojaId) ? meuMembro(lojaId).papel : null;
    }

    function podeEditar(lojaId) {
      return papel(lojaId) in ['admin', 'editor'];
    }

    function ehAdmin(lojaId) {
      return papel(lojaId) == 'admin';
    }

    // Validação mínima de um membro: o campo sensível é o papel; os demais
    // são de exibição. Lenient para não quebrar docs legados (só `papel`).
    function membroValido(d) {
      return d.papel in ['admin', 'editor', 'leitor']
        && (!('disabled' in d) || d.disabled is bool);
    }

    // Validação de forma de um item (espelha o schema zod de packages/core).
    function itemValido(d, lojaId) {
      return d.lojaId == lojaId
        && d.descricao is string && d.descricao.size() > 0
        && d.quantidade is int && d.quantidade > 0
        && d.codigoLegado is string && d.codigoLegado.size() > 0
        && d.categoria in ['acessibilidade_saude', 'mobiliario', 'cozinha',
                           'comemorativo', 'ritualistico', 'eletronicos', 'outros']
        && d.status in ['ativo', 'baixado', 'emprestado', 'manutencao']
        && d.fotos is list
        && d.criadoPor is string
        && d.atualizadoPor is string
        && d.criadoEm is timestamp
        && d.atualizadoEm is timestamp
        && (!('localizacao' in d) || d.localizacao is string)
        && (!('observacao' in d) || d.observacao is string)
        && (!('dataAquisicao' in d) || d.dataAquisicao == null || d.dataAquisicao is timestamp)
        && (!('valorEstimado' in d) || (d.valorEstimado is number && d.valorEstimado >= 0));
    }

    // Deny-by-default (documentação explícita; a proteção real vem de caminhos
    // não cobertos serem negados).
    match /{document=**} {
      allow read, write: if false;
    }

    match /lojas/{lojaId} {
      allow read: if ehMembroAtivo(lojaId);
      allow write: if ehAdmin(lojaId);

      // Gestão de membros feita pelo client (admin), protegida aqui.
      match /membros/{uid} {
        allow read: if ehAdmin(lojaId) || (request.auth != null && request.auth.uid == uid);
        allow create, update: if ehAdmin(lojaId) && membroValido(request.resource.data);
        allow delete: if false; // desativação lógica, nunca exclusão
      }

      // Contadores de papéis: piso de admin >= 1 garantido aqui (backstop do
      // "não remover o último admin", já que o client mantém o contador).
      match /system/{docId} {
        allow read: if ehAdmin(lojaId);
        allow write: if ehAdmin(lojaId)
          && request.resource.data.admin is int && request.resource.data.admin >= 1
          && request.resource.data.editor is int && request.resource.data.editor >= 0;
      }

      // Auditoria: só admin lê e cria; autor = usuário autenticado; imutável.
      match /auditLogs/{logId} {
        allow read: if ehAdmin(lojaId);
        allow create: if ehAdmin(lojaId)
          && request.resource.data.changedBy == request.auth.uid
          && request.resource.data.timestamp == request.time
          && request.resource.data.action in ['create', 'update-role', 'disable', 'enable'];
        allow update, delete: if false;
      }

      match /itens/{itemId} {
        allow read: if ehMembroAtivo(lojaId);
        allow create, update: if podeEditar(lojaId) && itemValido(request.resource.data, lojaId);
        allow delete: if podeEditar(lojaId);

        match /historico/{eventoId} {
          allow read: if ehMembroAtivo(lojaId);
          allow create: if podeEditar(lojaId)
            && request.resource.data.usuario == request.auth.uid
            && request.resource.data.timestamp == request.time
            && request.resource.data.acao in ['criacao', 'edicao', 'exclusao'];
          allow update, delete: if false;
        }
      }
    }
  }
}
